{
  "@context": {
    "@vocab": "https://schema.org/",
    "stencila": "https://stencila.org/"
  },
  "@type": "Article",
  "stencila:content": [
    {
      "@type": "stencila:Paragraph",
      "stencila:content": [
        {
          "@type": "Text",
          "value": {
            "string": "Figure-labeled code chunk with overlay:"
          }
        }
      ]
    },
    {
      "@type": "stencila:CodeChunk",
      "stencila:code": {
        "string": "plot(data)"
      },
      "programmingLanguage": "python",
      "stencila:labelType": "FigureLabel",
      "stencila:label": "1",
      "stencila:labelAutomatically": false,
      "caption": [
        {
          "@type": "stencila:Paragraph",
          "stencila:content": [
            {
              "@type": "Text",
              "value": {
                "string": "A code-generated figure with an annotation overlay."
              }
            }
          ]
        }
      ],
      "stencila:overlay": "<svg viewBox=\"0 0 800 600\" xmlns=\"http://www.w3.org/2000/svg\">\n  <circle cx=\"400\" cy=\"300\" r=\"80\" fill=\"none\" stroke=\"red\" stroke-width=\"6\" />\n  <text x=\"500\" y=\"310\" fill=\"red\" font-size=\"24\">Peak of interest</text>\n</svg>"
    },
    {
      "@type": "stencila:Paragraph",
      "stencila:content": [
        {
          "@type": "Text",
          "value": {
            "string": "Plain SVG code block in caption should not become overlay:"
          }
        }
      ]
    },
    {
      "@type": "stencila:CodeChunk",
      "stencila:code": {
        "string": "plot(other_data)"
      },
      "programmingLanguage": "python",
      "stencila:labelType": "FigureLabel",
      "stencila:label": "2",
      "stencila:labelAutomatically": false,
      "caption": [
        {
          "@type": "stencila:CodeBlock",
          "stencila:code": {
            "string": "<svg viewBox=\"0 0 10 10\" xmlns=\"http://www.w3.org/2000/svg\">\n  <circle cx=\"5\" cy=\"5\" r=\"4\" />\n</svg>"
          },
          "programmingLanguage": "svg"
        },
        {
          "@type": "stencila:Paragraph",
          "stencila:content": [
            {
              "@type": "Text",
              "value": {
                "string": "A figure whose caption includes an SVG example, not an overlay."
              }
            }
          ]
        }
      ]
    }
  ]
}