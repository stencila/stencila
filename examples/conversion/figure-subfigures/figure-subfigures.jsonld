      ],
      "stencila:content": [
        {
          "@type": "stencila:CodeChunk",
          "stencila:code": {
            "string": "hist(rnorm(1000), col = \"lightblue\", main = \"\")"
          },
          "programmingLanguage": "r",
          "stencila:labelType": "FigureLabel",
          "caption": [
            {
              "@type": "stencila:Paragraph",
              "stencila:content": [
                {
                  "@type": "Text",
                  "value": {
                    "string": "A light blue histogram of random normal values generated in R."
                  }
                }
              ]
            }
          ]
        },
        {
          "@type": "stencila:CodeChunk",
          "stencila:code": {
            "string": "{\n  \"data\": [\n    {\n      \"type\": \"bar\",\n      \"x\": [\"A\", \"B\", \"C\", \"D\", \"E\"],\n      \"y\": [4, 7, 2, 9, 5],\n      \"marker\": {\"color\": \"pink\"}\n    }\n  ],\n  \"layout\": {\n    \"xaxis\": {\"title\": {\"text\": \"Category\"}},\n    \"yaxis\": {\"title\": {\"text\": \"Value\"}}\n  }\n}"
          },
          "programmingLanguage": "plotly",
          "stencila:labelType": "FigureLabel",
          "caption": [
            {
              "@type": "stencila:Paragraph",
              "stencila:content": [
                {
                  "@type": "Text",
                  "value": {
                    "string": "A pink bar chart generated using Plotly."
                  }
                }
              ]
            }
          ]
