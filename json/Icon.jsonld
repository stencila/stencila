{
  "@id": "https://stencila.org/Icon",
  "name": "Icon",
  "license": "https://creativecommons.org/publicdomain/zero/1.0/",
  "@context": {
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "schema": "https://schema.org/",
    "stencila": "https://stencila.org/"
  },
  "@graph": [
    {
      "@id": "stencila:Icon",
      "@type": "rdfs:Class",
      "rdfs:label": "Icon",
      "rdfs:comment": "An icon, typically rendered using an icon font.",
      "rdfs:subClassOf": {
        "@id": "stencila:Entity"
      }
    },
    {
      "@id": "schema:name",
      "@type": "rdfs:Property",
      "rdfs:label": "name",
      "rdfs:comment": "The name of the icon e.g. \"clock\" or \"lucide:clock\".",
      "schema:domainIncludes": [
        {
          "@id": "schema:Thing"
        },
        {
          "@id": "stencila:Agent"
        },
        {
          "@id": "stencila:Button"
        },
        {
          "@id": "stencila:DatatableColumn"
        },
        {
          "@id": "stencila:DatatableColumnHint"
        },
        {
          "@id": "stencila:Directory"
        },
        {
          "@id": "stencila:ExecutionTag"
        },
        {
          "@id": "stencila:File"
        },
        {
          "@id": "stencila:Function"
        },
        {
          "@id": "stencila:Icon"
        },
        {
          "@id": "stencila:Parameter"
        },
        {
          "@id": "stencila:Skill"
        },
        {
          "@id": "stencila:TableCell"
        },
        {
          "@id": "stencila:Variable"
        },
        {
          "@id": "stencila:Workflow"
        }
      ],
      "schema:rangeIncludes": {
        "@id": "schema:Text"
      }
    },
    {
      "@id": "stencila:label",
      "@type": "rdfs:Property",
      "rdfs:label": "label",
      "rdfs:comment": "An accessible text label for the icon.",
      "schema:domainIncludes": [
        {
          "@id": "schema:Claim"
        },
        {
          "@id": "schema:Table"
        },
        {
          "@id": "stencila:Button"
        },
        {
          "@id": "stencila:CodeChunk"
        },
        {
          "@id": "stencila:Datatable"
        },
        {
          "@id": "stencila:Figure"
        },
        {
          "@id": "stencila:Heading"
        },
        {
          "@id": "stencila:Icon"
        },
        {
          "@id": "stencila:Island"
        },
        {
          "@id": "stencila:MathBlock"
        },
        {
          "@id": "stencila:Parameter"
        },
        {
          "@id": "stencila:Supplement"
        }
      ],
      "schema:rangeIncludes": {
        "@id": "schema:Text"
      }
    },
    {
      "@id": "stencila:decorative",
      "@type": "rdfs:Property",
      "rdfs:label": "decorative",
      "rdfs:comment": "Whether the icon is purely decorative.",
      "schema:domainIncludes": {
        "@id": "stencila:Icon"
      },
      "schema:rangeIncludes": {
        "@id": "schema:Boolean"
      }
    },
    {
      "@id": "stencila:style",
      "@type": "rdfs:Property",
      "rdfs:label": "style",
      "rdfs:comment": "Tailwind utility classes to apply to the icon.",
      "schema:domainIncludes": [
        {
          "@id": "stencila:Icon"
        },
        {
          "@id": "stencila:Island"
        }
      ],
      "schema:rangeIncludes": {
        "@id": "schema:Text"
      }
    }
  ]
}