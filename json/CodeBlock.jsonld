  },
  "@graph": [
    {
      "@id": "stencila:CodeBlock",
      "@type": "rdfs:Class",
      "rdfs:label": "CodeBlock",
      "rdfs:comment": "A code block.",
      "rdfs:subClassOf": {
        "@id": "stencila:CodeStatic"
      }
    },
    {
      "@id": "stencila:code",
      "@type": "rdfs:Property",
      "rdfs:label": "code",
      "rdfs:comment": "The code.",
