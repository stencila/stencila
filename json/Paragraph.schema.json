{
  "$schema": "https://stencila.org/meta.schema.json",
  "$id": "https://stencila.org/Paragraph.schema.json",
  "@id": "stencila:Paragraph",
  "title": "Paragraph",
  "nick": "pgh",
  "extends": [
    "Entity"
  ],
  "category": "prose",
  "description": "A paragraph.",
  "$comment": "This is a type used in Stencila Schema for paragraph content.\n\nIt exists to represent one of the main units of prose within the document\nmodel while also supporting authorship and provenance metadata not usually\navailable on plain text paragraphs in simpler formats.\n\nKey properties include the inline `content`, together with optional `authors`\nand `provenance` metadata.\n",
  "analogues": [
    {
      "id": "html:p"
    },
    {
      "id": "jats:p"
    },
    {
      "id": "pandoc:Para"
    },
    {
      "id": "mdast:Paragraph"
    }
  ],
  "html": {
    "elem": "p"
  },
  "jats": {
    "elem": "p"
  },
  "latex": {
    "derive": false
  },
  "markdown": {
    "derive": false
  },
  "proptest": {},
  "required": [
    "type",
    "content"
  ],
  "core": [
    "id",
    "authors",
    "provenance"
  ],
  "properties": {
    "type": {
      "@id": "schema:type",
      "description": "The type of this item.",
      "$comment": "This is a special property analogous to JSON-LD's `@type` keyword.\n",
      "type": "string"
    },
    "id": {
      "@id": "schema:id",
      "description": "The identifier for this item.",
      "$comment": "This is a special property analogous to JSON-LD's `@id` keyword.\n",
      "strip": [
        "metadata"
      ],
      "html": {
        "attr": "id"
      },
      "jats": {
        "attr": "id"
      },
      "type": "string"
    },
    "content": {
      "@id": "stencila:content",
      "description": "The contents of the paragraph.",
      "dom": {
        "elem": "p"
      },
      "proptest": {
        "min": {
          "description": "Generate a single arbitrary inline node",
          "strategy": "vec_inlines(1)"
        },
        "low": {
          "description": "Generate up to two arbitrary inline nodes",
          "strategy": "vec_inlines(2)"
        },
        "high": {
          "description": "Generate up to four arbitrary inline nodes",
          "strategy": "vec_inlines(4)"
        },
        "max": {
          "description": "Generate up to eight arbitrary inline nodes without restrictions on their order",
          "strategy": "vec(Inline::arbitrary(), size_range(0..=8))"
        }
      },
      "type": "array",
      "items": {
        "$ref": "Inline.schema.json"
      }
    },
    "authors": {
      "@id": "schema:author",
      "description": "The authors of the paragraph.",
      "aliases": [
        "author"
      ],
      "strip": [
        "authors"
      ],
      "serde": {
        "deserializeWith": "option_one_or_many_string_or_object"
      },
      "dom": {
        "elem": "div"
      },
      "type": "array",
      "items": {
        "$ref": "Author.schema.json"
      }
    },
    "provenance": {
      "@id": "stencila:provenance",
      "description": "A summary of the provenance of content within the paragraph.",
      "strip": [
        "provenance"
      ],
      "dom": {
        "elem": "div"
      },
      "type": "array",
      "items": {
        "$ref": "ProvenanceCount.schema.json"
      }
    }
  }
}