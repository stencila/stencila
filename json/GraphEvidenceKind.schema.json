{
  "$schema": "https://stencila.org/meta.schema.json",
  "$id": "https://stencila.org/GraphEvidenceKind.schema.json",
  "@id": "stencila:GraphEvidenceKind",
  "title": "GraphEvidenceKind",
  "extends": [
    "Enumeration"
  ],
  "category": "flow",
  "description": "The kind of evidence supporting a graph edge.",
  "$comment": "This enumeration classifies how a graph edge was learned or justified.\n`StaticAnalysis` is derived without running the document, such as parsing\nimports or references. `RuntimeObservation` is captured while code, tools, or\nworkflows run, such as an observed file read. `ExecutionMetadata` is imported\nfrom persisted Stencila execution state, such as dependencies or digests,\nrather than freshly observed during the current run.\n",
  "required": [
    "type"
  ],
  "core": [
    "id"
  ],
  "properties": {
    "type": {
      "@id": "schema:type",
      "description": "The type of this item.",
      "$comment": "This is a special property analogous to JSON-LD's `@type` keyword.\n",
      "type": "string"
    },
    "id": {
      "@id": "schema:id",
      "description": "The identifier for this item.",
      "$comment": "This is a special property analogous to JSON-LD's `@id` keyword.\n",
      "strip": [
        "metadata"
      ],
      "html": {
        "attr": "id"
      },
      "jats": {
        "attr": "id"
      },
      "type": "string"
    },
    "alternateNames": {
      "@id": "schema:alternateName",
      "description": "Alternate names (aliases) for the item.",
      "aliases": [
        "alternate-names",
        "alternate_names",
        "alternateName",
        "alternate-name",
        "alternate_name"
      ],
      "strip": [
        "metadata"
      ],
      "serde": {
        "deserializeWith": "option_csv_or_array"
      },
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "description": {
      "@id": "schema:description",
      "description": "A description of the item.",
      "strip": [
        "metadata"
      ],
      "patch": {
        "formats": [
          "md",
          "smd",
          "myst",
          "ipynb",
          "qmd"
        ]
      },
      "type": "string"
    },
    "identifiers": {
      "@id": "schema:identifier",
      "description": "Any kind of identifier for any kind of Thing.",
      "$comment": "Some identifiers have specific properties e.g the `issn` property for\nthe `Periodical` type. These should be used in preference to this\nproperty which is intended for identifiers that do not yet have a\nspecific property. Identifiers can be represented as strings, but\nusing a `PropertyValue` will usually be better because it allows\nfor `propertyID` (i.e. the type of identifier).\n",
      "aliases": [
        "identifier"
      ],
      "strip": [
        "metadata"
      ],
      "type": "array",
      "items": {
        "anyOf": [
          {
            "$ref": "PropertyValue.schema.json"
          },
          {
            "type": "string"
          }
        ]
      }
    },
    "images": {
      "@id": "schema:image",
      "description": "Images of the item.",
      "aliases": [
        "image"
      ],
      "strip": [
        "metadata"
      ],
      "type": "array",
      "items": {
        "$ref": "ImageObject.schema.json"
      }
    },
    "name": {
      "@id": "schema:name",
      "description": "The name of the item.",
      "strip": [
        "metadata"
      ],
      "type": "string"
    },
    "url": {
      "@id": "schema:url",
      "description": "The URL of the item.",
      "strip": [
        "metadata"
      ],
      "type": "string",
      "format": "uri"
    }
  },
  "anyOf": [
    {
      "@id": "stencila:StaticAnalysis",
      "description": "Evidence from static analysis.",
      "const": "StaticAnalysis"
    },
    {
      "@id": "stencila:RuntimeObservation",
      "description": "Evidence from observing runtime behavior.",
      "const": "RuntimeObservation"
    },
    {
      "@id": "stencila:UserAssertion",
      "description": "Evidence asserted by a user.",
      "const": "UserAssertion"
    },
    {
      "@id": "stencila:Imported",
      "description": "Evidence imported from another source.",
      "const": "Imported"
    },
    {
      "@id": "stencila:ContentCredential",
      "description": "Evidence from a content credential.",
      "const": "ContentCredential"
    },
    {
      "@id": "stencila:ExecutionMetadata",
      "description": "Evidence from execution metadata.",
      "const": "ExecutionMetadata"
    }
  ]
}