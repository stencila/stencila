      type: CodeChunk
      code:
        string: "outcome_matrix <- t(as.matrix(\n  summaries[, c(\"Mitotic entry (%)\", \"Apoptosis (%)\")]\n))\ncolnames(outcome_matrix) <- summaries$Treatment\n\nbarplot(\n  outcome_matrix,\n  beside = TRUE,\n..."
      programmingLanguage: r
      labelType: FigureLabel
      label: 1a
      caption:
        - type: Paragraph
