        string: "outcomes <- read.csv(\"outcomes.csv\")\n\nevent_totals <- aggregate(\n  cbind(mitotic_entries, apoptotic_cells) ~ treatment,\n  data = outcomes,\n  FUN = sum\n)\ncell_counts <- aggregate(cells_scored ~ treatment, data = outcomes, FUN = max)\n..."
      programmingLanguage: r
      labelType: TableLabel
      label: "1"
      caption:
