          "symbol:docs/notebook.json:python:samples" [label="samples", kind="symbol", shape="ellipse", style="filled", fillcolor="#eef6f4", color="#187b6b"];
          "symbol:docs/notebook.json:python:scale" [label="scale", kind="symbol", shape="ellipse", style="filled", fillcolor="#eef6f4", color="#187b6b"];
        }
        "node:docs/notebook.json#cde_content-3-content-1" [label="total", kind="code", shape="box", style="filled", fillcolor="#eef6f4", color="#187b6b"];
      }
    }
  }

  "node:docs/notebook.json#cdc_analysis" -> "symbol:docs/notebook.json:python:adjusted" [label="Generated", kind="Generated", count="1", evidence_count="1", action_count="0", low_confidence="false", style="solid", color="#4b5563"];
