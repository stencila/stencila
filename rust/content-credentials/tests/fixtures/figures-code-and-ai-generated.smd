    ::: figure

    ```r exec
    outcomes <- matrix(
      c(88, 55, 6, 31),
      nrow = 2,
      byrow = TRUE,
      dimnames = list(
        c("Mitotic entry", "Apoptosis"),
        c("Control", "Dox")
      )
    )

    barplot(
      outcomes,
      beside = TRUE,
      ylim = c(0, 100),
      col = c("#4e79a7", "#e15759"),
      border = "white",
      ylab = "Cells at 12 h (%)",
      legend.text = rownames(outcomes),
      args.legend = list(x = "topright", bty = "n", inset = 0.02),
      main = ""
    )
    ```

